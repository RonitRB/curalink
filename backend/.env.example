# Curalink Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/curalink?retryWrites=true&w=majority

# Groq API key (free at https://console.groq.com)
# Model used: llama-3.3-70b-versatile (open-source, Llama 3.3)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: NCBI API key for higher PubMed rate limits (free at https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=

# Frontend URL for CORS (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Server port
PORT=5000
